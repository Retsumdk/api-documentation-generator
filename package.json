{
  "name": "api-documentation-generator",
  "version": "1.0.0",
  "description": "Generate API documentation from code annotations and OpenAPI specs",
  "main": "dist/index.js",
  "bin": {
    "core": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node dist/index.js --path ./test/fixtures --output ./test/output --format markdown",
    "dev": "tsc --watch",
    "prepublish": "tsc"
  },
  "keywords": [
    "api",
    "documentation",
    "generator",
    "openapi",
    "jsdoc",
    "typescript"
  ],
  "author": "The BookMaster",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module"
}
